# .env-example — copy to .env and fill in your real values
# NEVER commit .env to git

# LLM Provider API Keys (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: choose which LLM provider to use (openai or anthropic)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# Optional: override default model parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Optional: output verbosity for the CrewAI pipeline (true/false)
CREWAI_VERBOSE=true
